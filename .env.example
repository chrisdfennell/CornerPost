# Copy this file to `.env` and adjust as needed.

# Prisma datasource. Defaults to a local SQLite file in /prisma.
DATABASE_URL="file:./dev.db"

# Public base URL, used for sitemap.xml / robots.txt absolute links.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secret token that unlocks the /moderation queue (visit /moderation?token=...).
# Leave unset to disable moderation entirely.
MODERATION_TOKEN=""

# Image uploads via UploadThing (https://uploadthing.com). Leave unset to hide
# the file uploader — posting still works by pasting image URLs.
UPLOADTHING_TOKEN=""

# Transactional email via Resend (https://resend.com). Leave unset to log the
# manage-link email to the server console instead of sending it.
RESEND_API_KEY=""
EMAIL_FROM="CornerPost <onboarding@resend.dev>"
